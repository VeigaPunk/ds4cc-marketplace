{
  "name": "@veigapunk/aaron",
  "version": "0.1.0",
  "type": "module",
  "description": "aaron — a minimal model-callable tool for fetching public-domain books (lib*) and papers (sci*/arxiv/semantic-scholar). CLI + MCP stdio server.",
  "main": "./build/aaron.js",
  "bin": {
    "aaron": "./build/aaron.js"
  },
  "homepage": "https://github.com/VeigaPunk/aaronplug",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target node --outfile ./build/aaron.js && echo '#!/usr/bin/env node' | cat - ./build/aaron.js > ./build/temp && mv ./build/temp ./build/aaron.js && chmod +x ./build/aaron.js",
    "compile": "bun run clean && bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:macos-x64 && bun run compile:macos-arm64 && bun run compile:windows-x64",
    "compile:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile ./standalone-executables/aaron-linux-x64",
    "compile:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile ./standalone-executables/aaron-linux-arm64",
    "compile:macos-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile ./standalone-executables/aaron-macos-x64",
    "compile:macos-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile ./standalone-executables/aaron-macos-arm64",
    "compile:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile ./standalone-executables/aaron-windows-x64.exe",
    "lint": "eslint 'src/**/*.{js,ts,json}'",
    "lint:fix": "eslint --fix 'src/**/*.{js,ts,json}'",
    "format": "prettier --write 'src/**/*.{js,ts,css,md,json}' --config ./.prettierrc",
    "clean": "rimraf ./build && rimraf ./standalone-executables"
  },
  "keywords": [
    "aaron",
    "libgen",
    "sci-hub",
    "arxiv",
    "cli",
    "books",
    "papers",
    "agent-tool"
  ],
  "author": "VeigaPunk",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/VeigaPunk/aaronplug.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/content-disposition": "^0.5.9",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "bun-types": "^1.3.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^63.0.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@opendocsg/pdf2md": "^0.2.6",
    "content-disposition": "^1.0.1",
    "linkedom": "^0.18.12",
    "meow": "^14.0.0",
    "nanoid": "^5.1.6"
  }
}
