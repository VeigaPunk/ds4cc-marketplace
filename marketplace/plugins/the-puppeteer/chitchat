#!/bin/bash
# Usage: chitchat [--model <name>] [--image|--deep-research|--web-search] [--stdin | "prompt"]
# Fire-and-forget ChatGPT web UI bridge over a dedicated loopback CDP browser.

set -euo pipefail

VERSION="1.2.0"

canonical_path() {
  local target=$1 link dir resolved
  if command -v readlink >/dev/null 2>&1; then
    if resolved=$(readlink -f -- "$target" 2>/dev/null) && [[ -n "$resolved" ]]; then
      printf '%s\n' "$resolved"
      return
    fi
  fi
  [[ "$target" == /* ]] || target="$PWD/$target"
  while [[ -L "$target" ]]; do
    dir=$(CDPATH= cd -P -- "$(dirname -- "$target")" && pwd)
    link=$(readlink -- "$target")
    [[ "$link" == /* ]] && target=$link || target="$dir/$link"
  done
  dir=$(CDPATH= cd -P -- "$(dirname -- "$target")" && pwd)
  printf '%s/%s\n' "$dir" "$(basename -- "$target")"
}

SCRIPT_PATH=$(canonical_path "$0")
SCRIPT_DIR=${SCRIPT_PATH%/*}
CHITCHAT_CDP_HOST="${CHITCHAT_CDP_HOST:-127.0.0.1}"
CHITCHAT_CDP_PORT="${CHITCHAT_CDP_PORT:-9222}"
CHITCHAT_CDP_PROFILE="${CHITCHAT_CDP_PROFILE:-$HOME/.local/share/ds4cc/chromium-cdp}"
CHITCHAT_CHROME_BIN="${CHITCHAT_CHROME_BIN:-chromium}"

usage() {
  cat <<'EOF'
Usage: chitchat [options] [--stdin | "prompt"]

Options:
  -m, --model <name>  pro, thinking, or instant
      --image         Use Create image mode
      --deep-research Use Deep research mode (--deep)
      --web-search    Use Web search mode (--web)
      --new-chat      Open a fresh ChatGPT tab before posting
      --stdin         Read the prompt from standard input
  -h, --help          Show this help
      --version       Show version
EOF
}

die() { printf 'chitchat: %s\n' "$*" >&2; exit 1; }

[[ "$CHITCHAT_CDP_PORT" =~ ^[0-9]{1,5}$ ]] || die "CHITCHAT_CDP_PORT must be numeric"
(( CHITCHAT_CDP_PORT >= 1 && CHITCHAT_CDP_PORT <= 65535 )) || die "CHITCHAT_CDP_PORT must be between 1 and 65535"
case "$CHITCHAT_CDP_HOST" in
  127.0.0.1|localhost|'[::1]') ;;
  *) [[ "${CHITCHAT_DANGEROUS_ALLOW_REMOTE_CDP:-}" == 1 ]] || \
    die "CHITCHAT_CDP_HOST must be loopback (127.0.0.1, localhost, or [::1]); set CHITCHAT_DANGEROUS_ALLOW_REMOTE_CDP=1 to override" ;;
esac
CHITCHAT_CDP_ENDPOINT="http://${CHITCHAT_CDP_HOST}:${CHITCHAT_CDP_PORT}"

MODEL=""
TOOL=""
READ_STDIN=false
NEW_CHAT=false
ARGS=()
while (($#)); do
  case "$1" in
    --model|-m)
      (($# >= 2)) || die "$1 requires a value"
      MODEL=$2
      shift 2
      ;;
    --image|--deep-research|--deep|--web-search|--web)
      [[ -z "$TOOL" ]] || die "composer mode options are mutually exclusive"
      case "$1" in
        --image) TOOL="Create image" ;;
        --deep-research|--deep) TOOL="Deep research" ;;
        --web-search|--web) TOOL="Web search" ;;
      esac
      shift
      ;;
    --stdin) READ_STDIN=true; shift ;;
    --new-chat) NEW_CHAT=true; shift ;;
    --help|-h) usage; exit 0 ;;
    --version) echo "chitchat $VERSION"; exit 0 ;;
    --) shift; ARGS+=("$@"); break ;;
    --*) die "unknown option: $1" ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

if $READ_STDIN; then
  ((${#ARGS[@]} == 0)) || die "--stdin cannot be combined with prompt arguments"
  PROMPT=$(cat)
else
  ((${#ARGS[@]} > 0)) || { usage >&2; exit 1; }
  PROMPT="${ARGS[*]}"
fi
[[ -n "$PROMPT" ]] || die "prompt must not be empty"

case "$MODEL" in
  ""|auto) MODEL_TESTID="" ;;
  pro|p) MODEL_TESTID="model-switcher-gpt-5-4-pro" ;;
  thinking|think|t) MODEL_TESTID="model-switcher-gpt-5-4-thinking" ;;
  instant|i) MODEL_TESTID="model-switcher-gpt-5-3" ;;
  *) die "unknown --model '$MODEL' (valid: pro, thinking, instant)" ;;
esac

cdp_ready() {
  curl --silent --fail --max-time 2 "${CHITCHAT_CDP_ENDPOINT}/json/version" >/dev/null 2>&1
}

ensure_chrome_cdp() {
  cdp_ready && return 0
  if [[ "$(uname -s)" == Linux ]] && command -v systemctl >/dev/null 2>&1 \
      && systemctl --user cat ds4cc-cdp.service >/dev/null 2>&1; then
    systemctl --user start ds4cc-cdp.service
  elif [[ -n "${WSL_DISTRO_NAME:-}" ]] || command -v cmd.exe >/dev/null 2>&1; then
    local chrome='C:\Program Files\Google\Chrome Dev\Application\chrome.exe'
    cmd.exe /C start "" "$chrome" --remote-debugging-port="$CHITCHAT_CDP_PORT" \
      '--user-data-dir=C:\ChromeAutomation' --no-first-run --no-default-browser-check >/dev/null 2>&1
  else
    printf 'CDP is unavailable at %s:%s. Start a dedicated browser:\n' "$CHITCHAT_CDP_HOST" "$CHITCHAT_CDP_PORT" >&2
    printf '  %q --remote-debugging-address=%q --remote-debugging-port=%q --user-data-dir=%q --no-first-run --no-default-browser-check\n' \
      "$CHITCHAT_CHROME_BIN" "$CHITCHAT_CDP_HOST" "$CHITCHAT_CDP_PORT" "$CHITCHAT_CDP_PROFILE" >&2
    return 1
  fi

  local waited=0 timeout_s="${CHITCHAT_CDP_TIMEOUT:-20}"
  while (( waited < timeout_s )); do
    cdp_ready && return 0
    sleep 1
    ((waited += 1))
  done
  die "CDP did not become ready at ${CHITCHAT_CDP_HOST}:${CHITCHAT_CDP_PORT} within ${timeout_s}s"
}

ensure_chrome_cdp
AGENT_BROWSER=(agent-browser --cdp "$CHITCHAT_CDP_ENDPOINT")
echo "→ Firing prompt into ChatGPT${MODEL:+ (model=$MODEL)}${TOOL:+ (tool=$TOOL)}..."

CHATGPT_IDX=$("${AGENT_BROWSER[@]}" tab list 2>&1 | grep -E '\[t[0-9]+\][[:space:]].*https?://chatgpt\.com' | grep -oE 't[0-9]+' | sed -n '1p' || true)
if $NEW_CHAT || [[ -z "$CHATGPT_IDX" ]]; then
  "${AGENT_BROWSER[@]}" tab new >/dev/null 2>&1
  "${AGENT_BROWSER[@]}" open https://chatgpt.com --wait 4000ms >/dev/null 2>&1
else
  "${AGENT_BROWSER[@]}" tab "$CHATGPT_IDX" >/dev/null 2>&1
fi

TITLE=""
PROMPT_READY=0
for _ in 1 2 3 4 5; do
  TITLE=$("${AGENT_BROWSER[@]}" eval "document.title" 2>&1 | grep -v '^[✓✗]' | tr -d '"' || true)
  PROMPT_READY=$("${AGENT_BROWSER[@]}" get count '#prompt-textarea' 2>/dev/null || echo 0)
  [[ "$PROMPT_READY" =~ ^[0-9]+$ && "$PROMPT_READY" -gt 0 ]] && break
  sleep 2
done
[[ "$PROMPT_READY" =~ ^[0-9]+$ && "$PROMPT_READY" -gt 0 ]] \
  || die "tab is not ready (title: ${TITLE:-unknown}; Cloudflare challenge or login redirect); clear it manually"

if [[ -n "$MODEL_TESTID" ]]; then
  "${AGENT_BROWSER[@]}" click '[data-testid="model-switcher-dropdown-button"]' >/dev/null 2>&1
  "${AGENT_BROWSER[@]}" wait 500 >/dev/null 2>&1
  if ! "${AGENT_BROWSER[@]}" click "[data-testid=\"$MODEL_TESTID\"]" >/dev/null 2>&1; then
    echo "chitchat: model '$MODEL' is unavailable; keeping the current model" >&2
    "${AGENT_BROWSER[@]}" press Escape >/dev/null 2>&1
  fi
fi

if [[ -n "$TOOL" ]]; then
  "${AGENT_BROWSER[@]}" click '[data-testid="composer-plus-btn"]' >/dev/null 2>&1
  "${AGENT_BROWSER[@]}" wait 700 >/dev/null 2>&1
  if ! "${AGENT_BROWSER[@]}" find text "$TOOL" click >/dev/null 2>&1; then
    echo "chitchat: tool '$TOOL' is unavailable; keeping the current mode" >&2
    "${AGENT_BROWSER[@]}" press Escape >/dev/null 2>&1
  fi
fi

BEFORE=$("${AGENT_BROWSER[@]}" get count '[data-message-author-role="user"]' 2>/dev/null || echo 0)
"${AGENT_BROWSER[@]}" focus '#prompt-textarea' >/dev/null 2>&1
printf '%s' "$PROMPT" | /usr/bin/node "$SCRIPT_DIR/chitchat-batch.mjs" | "${AGENT_BROWSER[@]}" batch --bail --json >/dev/null
sleep 2
AFTER=$("${AGENT_BROWSER[@]}" get count '[data-message-author-role="user"]' 2>/dev/null || echo 0)
GENERATING=$("${AGENT_BROWSER[@]}" get count 'button[aria-label*="Stop"]' 2>/dev/null || echo 0)
if { [[ "$AFTER" =~ ^[0-9]+$ && "$BEFORE" =~ ^[0-9]+$ ]] && (( AFTER > BEFORE )); } \
    || { [[ "$GENERATING" =~ ^[0-9]+$ ]] && (( GENERATING > 0 )); }; then
  echo "✓ Prompt fired. Read the reply in your ChatGPT browser tab."
else
  die "prompt may not have posted (user turns: ${BEFORE:-?} → ${AFTER:-?})"
fi
